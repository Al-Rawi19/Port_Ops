                      name="crane_cycle_seconds"
                      truncationRowDisposition="FailComponent">
                      <properties>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">[DATEDIFF]("ss",#{Package\Load fact_container_movement\OLE DB Source.Outputs[OLE DB Source Output].Columns[move_start_time]},#{Package\Load fact_container_movement\OLE DB Source.Outputs[OLE DB Source Output].Columns[move_end_time]})</property>
