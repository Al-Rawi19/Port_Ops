      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="data quality check"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{06C50CC6-6F5D-429B-8A2C-240CC7CDFE09}"
          SQLTask:SqlStatementSource="IF (SELECT COUNT(*) FROM stg.vessel_calls) = 0&#xA;BEGIN&#xA;    RAISERROR('DQ FAIL: stg.vessel_calls is empty. Run 01_Load_Staging first.', 16, 1);&#xA;END&#xA;&#xA;IF (SELECT COUNT(*) FROM stg.container_movements) = 0&#xA;BEGIN&#xA;    RAISERROR('DQ FAIL: stg.container_movements is empty.', 16, 1);&#xA;END&#xA;&#xA;-- Business rule: no move should end before it starts (Excel float comparison)&#xA;DECLARE @BadMoves INT = (&#xA;    SELECT COUNT(*) FROM stg.container_movements&#xA;    WHERE move_end_time &lt; move_start_time&#xA;      AND move_start_time IS NOT NULL&#xA;      AND move_end_time IS NOT NULL&#xA;);&#xA;IF @BadMoves &gt; 0&#xA;BEGIN&#xA;    INSERT INTO audit.load_errors (package_name, table_name, error_desc)&#xA;    VALUES ('04_Load_Facts', 'stg.container_movements',&#xA;            'DQ WARNING: ' + CAST(@BadMoves AS VARCHAR) + ' moves have end &lt; start time.');&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
