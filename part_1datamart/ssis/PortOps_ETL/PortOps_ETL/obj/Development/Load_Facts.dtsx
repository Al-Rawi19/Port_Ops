                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">[YEAR](#{Package\Load fact_container_movement\OLE DB Source.Outputs[OLE DB Source Output].Columns[move_start_time]}) * 10000 + [MONTH](#{Package\Load fact_container_movement\OLE DB Source.Outputs[OLE DB Source Output].Columns[move_start_time]}) * 100 + [DAY](#{Package\Load fact_container_movement\OLE DB Source.Outputs[OLE DB Source Output].Columns[move_start_time]})</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">YEAR(move_start_time) * 10000 + MONTH(move_start_time) * 100 + DAY(move_start_time)</property>
