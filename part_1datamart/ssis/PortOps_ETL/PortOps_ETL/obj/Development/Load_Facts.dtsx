                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    cm.movement_id,
    cm.vessel_call_id,
    cm.container_no,
    LTRIM(RTRIM(cm.container_size)) AS container_size,
    cm.move_type,
    cm.equipment_id,
    cm.shift_id,
    cm.customer_id,
    cm.terminal_id,
    CONVERT(DATETIME, DATEADD(SECOND,
        CAST((cm.move_start_time - FLOOR(cm.move_start_time)) * 86400 AS INT),
        DATEADD(DAY, CAST(cm.move_start_time AS INT) - 2, '1900-01-01')
    )) AS move_start_time,
    CONVERT(DATETIME, DATEADD(SECOND,
        CAST((cm.move_end_time - FLOOR(cm.move_end_time)) * 86400 AS INT),
        DATEADD(DAY, CAST(cm.move_end_time AS INT) - 2, '1900-01-01')
    )) AS move_end_time,
    cm.is_reefer,
    cm.weight_tons
FROM stg.container_movements cm</property>
