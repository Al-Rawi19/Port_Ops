                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    vc.vessel_call_id,
    vc.vessel_name,
    vc.voyage_no,
    vc.customer_id,
    vc.terminal_id,
    -- Convert Excel float dates to DATETIME
    CONVERT(DATETIME, DATEADD(SECOND,
        CAST((vc.eta - FLOOR(vc.eta)) * 86400 AS INT),
        DATEADD(DAY, CAST(vc.eta AS INT) - 2, '1900-01-01')
    )) AS eta,
    CONVERT(DATETIME, DATEADD(SECOND,
        CAST((vc.ata - FLOOR(vc.ata)) * 86400 AS INT),
        DATEADD(DAY, CAST(vc.ata AS INT) - 2, '1900-01-01')
    )) AS ata,
    CONVERT(DATETIME, DATEADD(SECOND,
        CAST((vc.atd - FLOOR(vc.atd)) * 86400 AS INT),
        DATEADD(DAY, CAST(vc.atd AS INT) - 2, '1900-01-01')
    )) AS atd,
    vc.total_moves_planned,
    vc.total_moves_actual,
    vc.status
FROM stg.vessel_calls vc</property>
