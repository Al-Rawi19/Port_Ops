                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    gt.gate_txn_id,
    gt.truck_plate,
    gt.container_no,
    gt.customer_id,
    gt.terminal_id,
    gt.direction,
    CONVERT(DATETIME, DATEADD(SECOND,
        CAST((gt.gate_in_time - FLOOR(gt.gate_in_time)) * 86400 AS INT),
        DATEADD(DAY, CAST(gt.gate_in_time AS INT) - 2, '1900-01-01')
    )) AS gate_in_time,
    CONVERT(DATETIME, DATEADD(SECOND,
        CAST((gt.gate_out_time - FLOOR(gt.gate_out_time)) * 86400 AS INT),
        DATEADD(DAY, CAST(gt.gate_out_time AS INT) - 2, '1900-01-01')
    )) AS gate_out_time,
    gt.shift_id
FROM stg.gate_transactions gt</property>
