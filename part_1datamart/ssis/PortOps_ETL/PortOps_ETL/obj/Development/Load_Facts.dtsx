      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{06C50CC6-6F5D-429B-8A2C-240CC7CDFE09}"
          SQLTask:SqlStatementSource="UPDATE audit.package_log&#xA;SET end_time = GETDATE(),&#xA;    status = 'Success',&#xA;    rows_staging = (&#xA;        SELECT SUM(row_count)&#xA;        FROM (&#xA;            SELECT COUNT(*) AS row_count FROM mart.dim_terminal&#xA;            UNION ALL &#xA;            SELECT COUNT(*) FROM mart.dim_equipment&#xA;            UNION ALL &#xA;            SELECT COUNT(*) FROM mart.dim_shift&#xA;        ) x&#xA;    )&#xA;WHERE package_name = 'Load_Facts'&#xA;  AND status = 'Running';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
