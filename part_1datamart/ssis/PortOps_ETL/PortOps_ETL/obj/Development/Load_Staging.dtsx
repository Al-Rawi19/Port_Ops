      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{06C50CC6-6F5D-429B-8A2C-240CC7CDFE09}"
          SQLTask:SqlStatementSource="UPDATE audit.package_log&#xA;SET end_time = GETDATE(),&#xA;    status = 'Success',&#xA;    rows_staging = (&#xA;        SELECT SUM(row_count) FROM (&#xA;            SELECT COUNT(*) AS row_count FROM stg.customers&#xA;            UNION ALL SELECT COUNT(*) FROM stg.customer_history&#xA;            UNION ALL SELECT COUNT(*) FROM stg.terminals&#xA;            UNION ALL SELECT COUNT(*) FROM stg.equipment&#xA;            UNION ALL SELECT COUNT(*) FROM stg.shifts&#xA;            UNION ALL SELECT COUNT(*) FROM stg.vessel_calls&#xA;            UNION ALL SELECT COUNT(*) FROM stg.container_movements&#xA;            UNION ALL SELECT COUNT(*) FROM stg.gate_transactions&#xA;        ) x&#xA;    )&#xA;WHERE package_name = 'Load_Staging'&#xA;  AND status = 'Running';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
