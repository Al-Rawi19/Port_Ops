      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{06C50CC6-6F5D-429B-8A2C-240CC7CDFE09}"
          SQLTask:SqlStatementSource="INSERT INTO audit.package_log (package_name, start_time, status)&#xA;VALUES ('01_Load_Staging', GETDATE(), 'Running');" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
