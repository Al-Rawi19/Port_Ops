          SQLTask:SqlStatementSource="UPDATE audit.package_log&#xA;SET end_time = GETDATE(),&#xA;    status = 'Success',&#xA;    rows_staging = (&#xA;        SELECT SUM(row_count) FROM (&#xA;            SELECT COUNT(*) AS row_countFROM mart.dim_terminal&#xA;            UNION ALL SELECT COUNT(*) FROM mart.dim_equipment&#xA;            UNION ALL SELECT COUNT(*) FROM mart.dim_shift&#xA;        ) x&#xA;    )&#xA;WHERE package_name = 'Load_Dim_Customer_SCD2'&#xA;  AND status = 'Running';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
