            <component
              refId="Package\Data Flow Task\OLE DB Source"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="OLE DB Source"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    ch.customer_id,
    c.customer_code,
    LTRIM(RTRIM(c.customer_name)) AS customer_name,
    c.country,
    ch.customer_tier,
    ch.credit_limit,
    c.active_flag,
    -- onboarded_date: normalize to nvarchar first, then handle serial or date string
    CASE
        WHEN TRY_CAST(CAST(c.onboarded_date AS NVARCHAR(50)) AS INT) IS NOT NULL
            THEN CONVERT(DATE, DATEADD(DAY, TRY_CAST(CAST(c.onboarded_date AS NVARCHAR(50)) AS INT) - 2, '1900-01-01'))
        ELSE TRY_CAST(CAST(c.onboarded_date AS NVARCHAR(50)) AS DATE)
    END AS onboarded_date,
    -- effective_from: normalize to nvarchar first, then handle serial or date string
    CASE
        WHEN TRY_CAST(CAST(ch.effective_from AS NVARCHAR(50)) AS INT) IS NOT NULL
            THEN CONVERT(DATE, DATEADD(DAY, TRY_CAST(CAST(ch.effective_from AS NVARCHAR(50)) AS INT) - 2, '1900-01-01'))
        ELSE TRY_CAST(CAST(ch.effective_from AS NVARCHAR(50)) AS DATE)
    END AS effective_from,
    -- effective_to: normalize to nvarchar first, then handle sentinel, serial, or date string
    CASE
        WHEN CAST(ch.effective_to AS NVARCHAR(50)) = '9999-12-31'
            THEN CAST('9999-12-31' AS DATE)
        WHEN TRY_CAST(CAST(ch.effective_to AS NVARCHAR(50)) AS INT) IS NOT NULL
            THEN CONVERT(DATE, DATEADD(DAY, TRY_CAST(CAST(ch.effective_to AS NVARCHAR(50)) AS INT) - 2, '1900-01-01'))
        ELSE TRY_CAST(CAST(ch.effective_to AS NVARCHAR(50)) AS DATE)
    END AS effective_to,
    CASE
        WHEN CAST(ch.effective_to AS NVARCHAR(50)) = '9999-12-31' THEN 1
        ELSE 0
    END AS is_current
FROM stg.customer_history ch
INNER JOIN stg.customers c ON ch.customer_id = c.customer_id
ORDER BY ch.customer_id, ch.effective_from</property>
