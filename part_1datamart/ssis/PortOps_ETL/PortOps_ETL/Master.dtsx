      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{06C50CC6-6F5D-429B-8A2C-240CC7CDFE09}"
          SQLTask:SqlStatementSource="INSERT INTO audit.package_log &#xA;    (package_name, start_time, status, error_message)&#xA;VALUES &#xA;    ('Master', GETDATE(), 'Failed', &#xA;     'Sub-package failed — see individual package logs');" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
