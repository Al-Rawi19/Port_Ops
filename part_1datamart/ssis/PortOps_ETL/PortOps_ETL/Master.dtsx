    <DTS:Executable
      DTS:refId="Package\Row Count Reconciliation"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{D455ABCC-5D91-40AD-8D4E-14B85AAE6ABA}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Row Count Reconciliation"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{06C50CC6-6F5D-429B-8A2C-240CC7CDFE09}"
          SQLTask:SqlStatementSource="DECLARE @SrcMoves   INT = (SELECT COUNT(*) FROM stg.container_movements);&#xA;DECLARE @TgtMoves   INT = (SELECT COUNT(*) FROM mart.fact_container_movement);&#xA;DECLARE @SrcGate    INT = (SELECT COUNT(*) FROM stg.gate_transactions);&#xA;DECLARE @TgtGate    INT = (SELECT COUNT(*) FROM mart.fact_gate_transaction);&#xA;DECLARE @SrcVessel  INT = (SELECT COUNT(*) FROM stg.vessel_calls);&#xA;DECLARE @TgtVessel  INT = (SELECT COUNT(*) FROM mart.fact_vessel_call);&#xA;&#xA;INSERT INTO audit.package_log&#xA;    (package_name, start_time, end_time, rows_source, &#xA;     rows_staging, rows_target, status)&#xA;VALUES (&#xA;    'Row_Reconciliation', GETDATE(), GETDATE(),&#xA;    @SrcMoves + @SrcGate + @SrcVessel,&#xA;    @SrcMoves + @SrcGate + @SrcVessel,&#xA;    @TgtMoves + @TgtGate + @TgtVessel,&#xA;    CASE&#xA;        WHEN @SrcMoves  = @TgtMoves&#xA;         AND @SrcGate   = @TgtGate&#xA;         AND @SrcVessel = @TgtVessel&#xA;        THEN 'Success'&#xA;        ELSE 'Warning - Row Count Mismatch'&#xA;    END&#xA;);&#xA;&#xA;IF ABS(@SrcMoves - @TgtMoves) * 100.0 / NULLIF(@SrcMoves, 0) &gt; 1&#xA;BEGIN&#xA;    RAISERROR('ROW COUNT WARNING: container_movements source=%d target=%d', &#xA;              1, 1, @SrcMoves, @TgtMoves);&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
